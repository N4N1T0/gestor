    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.14",
    "husky": "^9.1.7",
    "lucide-react": "^1.8.0",
    "next": "16.1.7",
    "next-safe-action": "^8.5.2",
    "next-themes": "^0.4.6",
    "node-appwrite": "20.0.0",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
